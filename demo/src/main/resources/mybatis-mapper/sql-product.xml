<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.ProductMapper">
	<!--여러 개 검색-->
	<select id="selectOrderList" parameterType="hashmap" resultType="com.example.demo.model.Product">
		SELECT 
			P.PRODUCT_ID,
			PRODUCT_NAME, 
			ROUND(SUM(ORDER_QTY * ORDER_PRICE)) AS SUM_PRICE                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             
		FROM PRODUCT P
		LEFT JOIN PRODUCT_ORDERS O ON P.PRODUCT_ID = O.PRODUCT_ID
		GROUP BY P.PRODUCT_ID, PRODUCT_NAME
	</select>
	<!--한 개 검색-->
	<select id="selectUser" parameterType="hashmap" resultType="com.example.demo.model.Product">
	
	</select>
	
	<!--삽입-->
	<insert id="insertUser" parameterType="hashmap">
	
	</insert>
	
	<!--삭제-->
	<delete id="deleteUser" parameterType="hashmap">
	
	</delete>
	
	<!--수정-->
	<update id="updateUser" parameterType="hashmap">
	
	</update>
</mapper>